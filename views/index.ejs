<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartPark - Đỗ Xe Thông Minh</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.10.0/dist/leaflet.css" integrity="sha256-sA+e2Hq6aYp3f3qk8Jgvmw9MNuHf6k9g+v+0s+1wE+M=" crossorigin=""/>
</head>
<body>

    <!-- THANH ĐIỀU HƯỚNG -->
    <header>
        <div class="nav-left">
            <div class="logo">SmartPark</div>
            <nav class="nav-links">
                <a href="/">Trang chủ</a>
                <a href="#booking-form">Bãi Xe</a>
                <a href="#promotions">Khuyến mãi</a>
                <a href="#news">Tin tức</a>
                <a href="#contact-section">Liên hệ</a>
            </nav>
        </div>
        <div class="auth-buttons">
            <a href="/login" class="btn-register">Đăng ký</a>
            <a href="/login" class="btn-login">Đăng nhập</a>
        </div>
    </header>

    <!-- SLIDESHOW 5 ẢNH -->
    <section class="slider-container">
        <div class="slider-wrapper" id="slider">
            
            <img class="slide" src="/images/slide1.avif" alt="Slide 1">
    <img class="slide" src="/images/slide2.avif" alt="Slide 2">
    <img class="slide" src="/images/slide3.avif" alt="Slide 3">
    <img class="slide" src="/images/slide4.jpg" alt="Slide 4">
        </div>
    </section>

    
    <section class="booking-section" id="booking-form">
      <h2 style="margin-bottom: 20px; color: var(--primary-green);">🅿️ Tìm Bãi Đỗ Xe & Bản đồ</h2>
      <div class="parking-search-container">
        <!-- LEFT: Filters & Map -->
        <aside class="search-panel">
          <div class="search-card">
            <label for="search-location">Tìm theo địa điểm</label>
            <input id="search-location" type="text" placeholder="Nhập địa điểm, quận, tên bãi..." />

            <div class="filter-group">
              <label>Lọc theo tiện ích:</label>
              <div class="filters">
                <label><input type="checkbox" value="ev_charging" /> Sạc EV</label>
                <label><input type="checkbox" value="cctv" /> Camera (CCTV)</label>
                <label><input type="checkbox" value="covered" /> Có mái che</label>
                <label><input type="checkbox" value="monthly" /> Gói tháng</label>
                <label><input type="checkbox" value="valet" /> Valet</label>
              </div>
            </div>

            <div class="map-wrapper">
              <div id="map" style="height:300px;border-radius:8px;"></div>
            </div>
          </div>
        </aside>

        <!-- RIGHT: Parking Grid -->
        <div class="parking-results">
          <div class="parking-lots-grid" id="parking-grid">
                <% parkingLots.forEach(lot => { %>
                  <a href="/parking/<%= lot.id %>" class="parking-lot-card" data-amenities="<%= lot.amenities.join(',') %>" data-lat="<%= lot.coords.lat %>" data-lng="<%= lot.coords.lng %>">
                    <img src="<%= lot.image %>" class="lot-image" alt="<%= lot.name %>" referrerPolicy="no-referrer">
                    <div class="lot-header">
                      <h3><%= lot.name %></h3>
                      <div class="lot-badge" id="badge-<%= lot.id %>"><%= lot.getAvailabilityPercent() %>%</div>
                    </div>

                    <div class="lot-info">
                      <p class="lot-address">📍 <%= lot.address %></p>
                      <div class="lot-stats">
                        <div class="stat"><span class="stat-icon">🅿️</span><span><strong><%= lot.availableSlots %></strong>/<%= lot.totalSlots %> trống</span></div>
                        <div class="stat"><span class="stat-icon">💰</span><span>₫<%= lot.pricePerHour.toLocaleString() %>/h</span></div>
                      </div>

                      <div class="amenities">
                        <% lot.amenities.forEach(a => { %>
                          <% 
                            const nameMap = { 
                              ev_charging: '🔌 Sạc EV', 
                              cctv: '🛡️ Camera CCTV', 
                              covered: '☂️ Có mái che', 
                              monthly: '📅 Gói tháng', 
                              valet: '🤵 Valet Parking' 
                            }; 
                          %>
                          <span class="amenity"><%= nameMap[a] || a %></span>
                        <% }); %>
                      </div>

                    </div>

                    <div class="lot-footer">
                      <span class="lot-status <%= lot.getStatus() === 'Hết chỗ' ? 'full' : '' %>"><%= lot.getStatus() %></span>
                      <span class="lot-cta">Đặt chỗ →</span>
                    </div>
                  </a>
                <% }); %>
          </div>
        </div>
      </div>
    </section>

    <!-- KHUYẾN MÃI -->
    <section class="info-section" id="promotions">
        <h2 class="section-title">KHUYẾN MÃI NỔI BẬT</h2>
        <div class="card-grid">
            <div class="card">
                <img src="/images/khuyen%20mai%2020%25.jpg" alt="Khuyến mãi 20%">
                <div class="card-content">
                    <h3>Giảm 20% khi đặt trước 24h</h3>
                    <p>Áp dụng cho khách hàng sử dụng dịch vụ đỗ xe qua đêm tại tầng hầm B2.</p>
                </div>
            </div>
            <div class="card">
                <img src="/images/hoantien.jpg" alt="Hoàn tiền 50K">
                <div class="card-content">
                    <h3>Hoàn tiền 50K khi quét VNPAY</h3>
                    <p>Thanh toán bằng QR Code qua ứng dụng ngân hàng để nhận ưu đãi ngay hôm nay.</p>
                </div>
            </div>
            <div class="card">
                <img src="/images/goi1tr2.png" alt="Gói 1.200.000đ">
                <div class="card-content">
                    <h3>Gói đỗ xe tháng chỉ 1.200.000đ</h3>
                    <p>Tiết kiệm hơn với gói cước tháng dành cho nhân viên văn phòng trong toà nhà.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- TIN TỨC -->
    <section class="info-section" id="news" style="margin-bottom: 80px;">
        <h2 class="section-title">TIN TỨC HOẠT ĐỘNG</h2>
        <div class="card-grid">
            <div class="card">
                <img src="/images/lap%20camera.jpg" alt="Lắp camera AI">
                <div class="card-content">
                    <h3>Nâng cấp hệ thống Camera nhận diện biển số AI</h3>
                    <p>SmartPark vừa đưa vào hoạt động hệ thống AI giúp xe ra vào không cần quẹt thẻ vật lý.</p>
                </div>
            </div>
            <div class="card">
                <img src="/images/baotri.jpg" alt="Bảo trì hầm B1">
                <div class="card-content">
                    <h3>Thông báo bảo trì hầm B1 ngày 20/07</h3>
                    <p>Để đảm bảo chất lượng, bãi đỗ sẽ tạm ngưng nhận xe hầm B1 từ 22h - 05h sáng hôm sau.</p>
                </div>
            </div>
        </div>
    </section>
    
    <!-- PHẦN LIÊN HỆ (CONTACT) -->
    <section class="contact-section">
    <div class="contact-container" id="contact-section">
    <!-- Cột bên trái -->
    <div class="contact-info">
        <h3>Công Ty Cổ Phần Đỗ Xe Thông Minh SmartPark</h3>
        <p class="contact-item"><strong>📍 Địa chỉ:</strong> 828 Sư Vạn Hạnh, Phường 13, Quận 10, TP. Hồ Chí Minh</p>
        <p class="contact-item"><strong>📞 Tổng đài đặt chỗ:</strong> <span class="orange-text">1900 6067</span> (24/7)</p>
        <p class="contact-item"><strong>📱 Hotline phản ánh:</strong> 028.3838.3838</p>
        <p class="contact-item"><strong>✉️ Email:</strong> hotro@smartpark.vn</p>
        <p class="contact-item"><strong>🌐 Website:</strong> www.smartpark.vn</p>
    </div>

    <!-- Cột bên phải -->
    <div class="contact-map">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.460228994796!2d106.66453627570319!3d10.776019559196347!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f131!3m3!1m2!1m5!1s0x31752edba51c1439%3A0xa19db3c8008740c0!2zODI4IFPGsCBW4bqhbiBI4bqhbmcsIFBox4budbmcgMTMsIFF14bqtbiAxMCwgSOG7kyBDaMOtIE1pbmgsIFZp4buHdCBOYW0!5e0!3m2!1svi!2s!4v1710000000000!5m2!1svi!2s" loading="lazy" allowfullscreen="" referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
</div>
</section>
    <!-- JAVASCRIPT CHO HIỆU ỨNG SLIDER TRƯỢT 5 GIÂY -->
    <script>
        const sliderWrapper = document.getElementById('slider');
        const totalSlides = 4; // Bạn có 5 ảnh
        let currentIndex = 0;

        // Hàm tự động chạy mỗi 5000ms (5 giây)
        setInterval(() => {
            currentIndex++;
            
            // Nếu đã trượt hết 5 ảnh thì quay lại ảnh đầu tiên
            if (currentIndex >= totalSlides) {
                currentIndex = 0;
            }
            
            // Dịch chuyển khối slider một khoảng tương ứng với Index (-100%, -200%...)
            sliderWrapper.style.transform = `translateX(-${currentIndex * 100}%)`;
        }, 5000);

        // Set badge colors dynamically based on availability
        document.querySelectorAll('[id^="badge-"]').forEach(badge => {
            const percentText = badge.textContent.trim();
            const percent = parseInt(percentText);
            if (percent <= 50) {
                badge.style.background = '#f59e0b';
            } else {
                badge.style.background = 'var(--primary-green)';
            }
        });

        // === Parking search + Map (Leaflet) using API + fetch ===
        (function initMap(){
            const LScript = document.createElement('script');
            LScript.src = 'https://unpkg.com/leaflet@1.10.0/dist/leaflet.js';
            LScript.onload = async () => {
                const map = L.map('map').setView([10.776, 106.664], 14);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(map);

                const markers = {};
                const grid = document.getElementById('parking-grid');

                const nameMap = { 
                    ev_charging: '🔌 Sạc EV', 
                    cctv: '🛡️ Camera CCTV', 
                    covered: '☂️ Có mái che', 
                    monthly: '📅 Gói tháng', 
                    valet: '🤵 Valet Parking' 
                };

                // Fetch parking data from API
                try {
                    const res = await fetch('/api/parking-lots');
                    const parkingData = await res.json();

                    // Render cards
                    function renderCards(data){
                        grid.innerHTML = '';
                        data.forEach(lot => {
                            const a = document.createElement('a');
                            a.href = '/parking/' + lot.id;
                            a.className = 'parking-lot-card';
                            a.setAttribute('data-amenities', (lot.amenities || []).join(','));
                            a.setAttribute('data-lat', lot.coords ? lot.coords.lat : lot.lat);
                            a.setAttribute('data-lng', lot.coords ? lot.coords.lng : lot.lng);

                            const available = lot.availableSlots !== undefined ? lot.availableSlots : (lot.available !== undefined ? lot.available : 0);
                            const total = lot.totalSlots !== undefined ? lot.totalSlots : (lot.total !== undefined ? lot.total : 100);
                            const price = lot.pricePerHour !== undefined ? lot.pricePerHour : (lot.price !== undefined ? lot.price : 15000);
                            const percent = Math.round((available / total) * 100);
                            const status = available === 0 ? 'Hết chỗ' : (available <= 5 ? 'Sắp hết' : 'Còn chỗ');

                            a.innerHTML = `
                                <img src="${lot.image}" class="lot-image" alt="${escapeHtml(lot.name)}" referrerPolicy="no-referrer">
                                <div class="lot-header">
                                  <h3>${escapeHtml(lot.name)}</h3>
                                  <div class="lot-badge" id="badge-${lot.id}">${percent}%</div>
                                </div>
                                <div class="lot-info">
                                  <p class="lot-address">📍 ${escapeHtml(lot.address || lot.adress || '')}</p>
                                  <div class="lot-stats">
                                    <div class="stat"><span class="stat-icon">🅿️</span><span><strong>${available}</strong>/${total} trống</span></div>
                                    <div class="stat"><span class="stat-icon">💰</span><span>₫${Number(price).toLocaleString()}/h</span></div>
                                  </div>
                                  <div class="amenities">
                                    ${(lot.amenities||[]).map(a => `<span class="amenity">${escapeHtml(nameMap[a] || a)}</span>`).join('')}
                                  </div>
                                </div>
                                <div class="lot-footer">
                                  <span class="lot-status ${status === 'Hết chỗ' ? 'full' : ''}">${status}</span>
                                  <span class="lot-cta">Đặt chỗ →</span>
                                </div>
                            `;

                            grid.appendChild(a);

                            // Marker
                            const lat = lot.coords ? lot.coords.lat : lot.lat;
                            const lng = lot.coords ? lot.coords.lng : lot.lng;
                            if (lat && lng) {
                                const marker = L.marker([lat, lng]).addTo(map).bindPopup(`
                                    <div style="font-family: sans-serif; font-size: 13px;">
                                        <img src="${lot.image}" style="width:100%; height:90px; object-fit:cover; border-radius:4px; margin-bottom:5px;">
                                        <strong>${escapeHtml(lot.name)}</strong><br/>
                                        📍 ${escapeHtml(lot.address || '')}<br/>
                                        💰 ₫${Number(price).toLocaleString()}/h<br/>
                                        🟢 Trống: <strong>${available}</strong>/${total}
                                    </div>
                                `);
                                marker.on('click', () => { window.location.href = '/parking/' + lot.id; });
                                markers[lot.id] = marker;
                            }
                        });

                        // Set badge colors
                        document.querySelectorAll('[id^="badge-"]').forEach(badge => {
                            const percentText = badge.textContent.trim();
                            const percent = parseInt(percentText);
                            if (percent <= 50) badge.style.background = '#f59e0b'; else badge.style.background = 'var(--primary-green)';
                        });

                        // Auto adjust bounds of map to show all markers beautifully
                        const markerList = Object.values(markers);
                        if (markerList.length > 0) {
                            const group = L.featureGroup(markerList);
                            map.fitBounds(group.getBounds().pad(0.15));
                        }
                    }

                    // Filtering logic
                    const searchInput = document.getElementById('search-location');
                    const checkboxes = Array.from(document.querySelectorAll('.filters input[type="checkbox"]'));

                    function applyFilters(){
                        const q = searchInput.value.trim().toLowerCase();
                        const activeAmenities = checkboxes.filter(cb => cb.checked).map(cb => cb.value);

                        const visibleMarkers = [];

                        document.querySelectorAll('.parking-lot-card').forEach(card => {
                            const title = card.querySelector('.lot-header h3').textContent.toLowerCase();
                            const addr = card.querySelector('.lot-address').textContent.toLowerCase();
                            const amenities = card.getAttribute('data-amenities') || '';

                            const matchesQuery = !q || title.includes(q) || addr.includes(q);
                            const matchesAmenities = activeAmenities.every(a => amenities.includes(a));

                            const id = card.getAttribute('href').split('/').pop();
                            if (matchesQuery && matchesAmenities) {
                                card.style.display = '';
                                if (markers[id]) {
                                    markers[id].addTo(map);
                                    visibleMarkers.push(markers[id]);
                                }
                            } else {
                                card.style.display = 'none';
                                if (markers[id]) map.removeLayer(markers[id]);
                            }
                        });

                        // Auto-adjust bounds for filtered results if there are any visible markers
                        if (visibleMarkers.length > 0) {
                            const group = L.featureGroup(visibleMarkers);
                            map.fitBounds(group.getBounds().pad(0.15));
                        }
                    }

                    // Debounce helper
                    function debounce(fn, ms){ let t; return (...args) => { clearTimeout(t); t = setTimeout(()=> fn(...args), ms); }; }

                    // Helpers
                    function escapeHtml(str){ return String(str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/\'/g, '&#39;'); }

                    // Initialize render and filters
                    renderCards(parkingData);
                    searchInput.addEventListener('input', debounce(applyFilters,250));
                    checkboxes.forEach(cb => cb.addEventListener('change', applyFilters));

                } catch(err){
                    console.error('Lỗi khi tải danh sách bãi xe', err);
                    document.getElementById('parking-grid').innerHTML = '<p>Không thể tải danh sách bãi xe lúc này. Vui lòng thử lại sau.</p>';
                }
            };
            document.head.appendChild(LScript);
        })();

        // Update header if user is logged in
        const userStr = localStorage.getItem('smartpark_user');
        if (userStr) {
            try {
                const user = JSON.parse(userStr);
                const authButtons = document.querySelector('.auth-buttons');
                if (authButtons) {
                    authButtons.innerHTML = `
                        <span style="color: white; margin-right: 15px; font-weight: 500;">👋 Chào, ${user.fullName} (${user.licensePlate})</span>
                        <button onclick="logout()" class="btn-login" style="cursor: pointer; border: none; background: #e11d48; padding: 6px 15px; border-radius: 4px; color: white;">Đăng xuất</button>
                    `;
                }
            } catch (e) {
                console.error(e);
            }
        }

        function logout() {
            localStorage.removeItem('smartpark_user');
            window.location.reload();
        }
    </script>
</body>
</html>
