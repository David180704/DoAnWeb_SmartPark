<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= lotName %> - SmartPark</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/parking.css">
</head>
<body>

    <!-- HEADER -->
    <header>
        <div class="nav-left">
            <a href="/" class="logo" style="text-decoration: none; color: white;">SmartPark</a>
            <nav class="nav-links">
                <a href="/">Trang chủ</a>
                <a href="#booking-form">Đặt chỗ</a>
                <a href="/#promotions">Khuyến mãi</a>
                <a href="/#news">Tin tức</a>
                <a href="/#contact-section">Liên hệ</a>
            </nav>
        </div>
        <div class="auth-buttons">
            <a href="/login" class="btn-register">Đăng ký</a>
            <a href="/login" class="btn-login">Đăng nhập</a>
        </div>
    </header>

    <!-- BREADCRUMB -->
    <div class="breadcrumb">
        <a href="/">Trang chủ</a>
        <span> / </span>
        <span>Bãi xe: <%= lotName %></span>
    </div>

    <!-- PARKING LOT HEADER -->
    <section class="parking-header">
        <div class="parking-header-content">
            <div class="parking-header-left">
                <h1><%= lotName %></h1>
                <div class="parking-meta">
                    <div class="meta-item">
                        <span class="meta-icon">📍</span>
                        <span><%= address %></span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-icon">⭐</span>
                        <span><%= rating %>/5 (<%= reviews %> đánh giá)</span>
                    </div>
                </div>
            </div>
            <div class="parking-stats">
                <div class="stat-card">
                    <div class="stat-value"><%= availableSlots %></div>
                    <div class="stat-label">Chỗ Trống</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value"><%= totalSlots %></div>
                    <div class="stat-label">Tổng Chỗ</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">₫<%= pricePerHour.toLocaleString() %></div>
                    <div class="stat-label">/Giờ</div>
                </div>
            </div>
        </div>
    </section>

    <!-- MAIN CONTENT -->
    <div class="parking-container">
        <!-- LEFT SIDE - BOOKING FORM -->
        <aside class="booking-aside">
            <!-- LOT IMAGE AND AMENITIES -->
            <div class="lot-detail-card" style="background: white; border-radius: 16px; margin-bottom: 20px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.1); border: 1px solid #eee;">
                <img src="<%= image %>" style="width: 100%; height: 180px; object-fit: cover;" referrerPolicy="no-referrer">
                <div style="padding: 20px;">
                    <h3 style="font-size: 15px; font-weight: 700; margin-bottom: 12px; color: #333;">🎁 Tiện ích bãi đỗ xe:</h3>
                    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                        <% amenities.forEach(a => { %>
                            <% 
                              const nameMap = { 
                                ev_charging: '🔌 Sạc EV', 
                                cctv: '🛡️ Camera CCTV', 
                                covered: '☂️ Có mái che', 
                                monthly: '📅 Gói tháng', 
                                valet: '🤵 Valet Parking' 
                              }; 
                            %>
                            <span class="amenity" style="font-size: 12px; padding: 4px 10px; background: #f4f8f6; border-radius: 8px; color: #2d6b3b; border: 1px solid rgba(16,185,129,0.12);"><%= nameMap[a] || a %></span>
                        <% }); %>
                    </div>
                </div>
            </div>

            <div class="booking-form-card" id="booking-form">
                <h2>Đặt Chỗ Đỗ Xe</h2>
                
                <form id="parking-form" class="parking-form">
                    <!-- Biển số xe -->
                    <div class="form-group">
                        <label for="plate">Biển Số Xe</label>
                        <input 
                            type="text" 
                            id="plate"
                            name="plate"
                            placeholder="Ví dụ: 30F-123.45"
                            required
                        >
                    </div>

                    <!-- Loại xe -->
                    <div class="form-group">
                        <label for="vehicle-type">Loại Xe</label>
                        <select id="vehicle-type" name="vehicleType" required>
                            <option value="car">Ô tô 4-7 chỗ</option>
                            <option value="suv">SUV/Bán tải</option>
                            <option value="moto">Xe máy</option>
                            <option value="ev">Xe điện</option>
                        </select>
                    </div>

                    <!-- Ngày đặt -->
                    <div class="form-group">
                        <label for="parking-date">Ngày Đặt</label>
                        <input 
                            type="date" 
                            id="parking-date"
                            name="date"
                            required
                        >
                    </div>

                    <!-- Thời gian -->
                    <div class="form-row">
                        <div class="form-group">
                            <label for="start-time">Giờ Vào</label>
                            <input 
                                type="time" 
                                id="start-time"
                                name="startTime"
                                required
                            >
                        </div>
                        <div class="form-group">
                            <label for="end-time">Giờ Ra</label>
                            <input 
                                type="time" 
                                id="end-time"
                                name="endTime"
                                required
                            >
                        </div>
                    </div>

                    <!-- Thống kê giờ -->
                    <div class="hours-summary">
                        <span class="hours-label">Thời gian:</span>
                        <span class="hours-value"><span id="hours-display">3</span> giờ</span>
                    </div>

                    <!-- Giá tiền -->
                    <div class="price-summary">
                        <div class="price-row">
                            <span>Giá/giờ:</span>
                            <span>₫<%= pricePerHour.toLocaleString() %></span>
                        </div>
                        <div class="price-row">
                            <span>Số giờ:</span>
                            <span><span id="hours-calc">3</span> h</span>
                        </div>
                        <div class="price-total">
                            <span>Tổng tiền:</span>
                            <span id="total-price">₫<%= (pricePerHour * 3).toLocaleString() %></span>
                        </div>
                    </div>

                    <!-- Button -->
                    <button type="submit" class="btn btn-primary btn-book">
                        💳 Tiếp Tục Thanh Toán
                    </button>
                </form>
            </div>
        </aside>

        <!-- RIGHT SIDE - PARKING GRID -->
        <main class="parking-main">
            <!-- TAB CHỌN KHU -->
            <div class="zone-tabs">
                <% zones.forEach(zone => { %>
                    <button class="zone-btn" onclick="filterZone('<%= zone %>')">
                        <%= zone %>
                    </button>
                <% }); %>
            </div>

            <!-- PARKING GRID -->
            <div class="parking-grid" id="parking-grid">
                <% for (let i = 1; i <= 30; i++) { %>
                    <div class="parking-slot available" onclick="selectSlot(this, 'A<%= i %>')">
                        <div class="slot-number">A<%= i %></div>
                        <div class="slot-status">Trống</div>
                        <div class="slot-price">₫<%= pricePerHour.toLocaleString() %></div>
                    </div>
                <% } %>
                <% for (let i = 1; i <= 5; i++) { %>
                    <div class="parking-slot occupied">
                        <div class="slot-number">Đã đặt</div>
                        <div class="slot-status">Hết</div>
                    </div>
                <% } %>
            </div>

            <!-- LEGEND -->
            <div class="parking-legend">
                <div class="legend-item">
                    <div class="legend-box available"></div>
                    <span>Trống</span>
                </div>
                <div class="legend-item">
                    <div class="legend-box occupied"></div>
                    <span>Đã đặt</span>
                </div>
                <div class="legend-item">
                    <div class="legend-box selected"></div>
                    <span>Bạn chọn</span>
                </div>
            </div>
        </main>
    </div>

    <!-- SELECTED SLOTS SUMMARY -->
    <div class="selected-summary" id="selected-summary" style="display: none;">
        <span>Chỗ đã chọn:</span>
        <span id="selected-slots-list">Chưa chọn</span>
    </div>

    <!-- JAVASCRIPT -->
    <script>
        const pricePerHour = <%= pricePerHour %>;
        const selectedSlots = new Set();

        // Set default date
        document.getElementById('parking-date').valueAsDate = new Date();

        // Calculate hours and price
        function updateHours() {
            const startTime = document.getElementById('start-time').value;
            const endTime = document.getElementById('end-time').value;

            if (startTime && endTime) {
                const [startH, startM] = startTime.split(':').map(Number);
                const [endH, endM] = endTime.split(':').map(Number);

                let startDecimal = startH + startM / 60;
                let endDecimal = endH + endM / 60;

                if (endDecimal <= startDecimal) {
                    endDecimal = startDecimal + 1;
                }

                const hours = Math.ceil((endDecimal - startDecimal) * 10) / 10;
                const totalPrice = Math.round(pricePerHour * hours);

                document.getElementById('hours-display').textContent = hours;
                document.getElementById('hours-calc').textContent = hours;
                document.getElementById('total-price').textContent = '₫' + totalPrice.toLocaleString();
            }
        }

        // Select parking slot
        function selectSlot(element, slotCode) {
            if (element.classList.contains('occupied')) return;

            element.classList.toggle('selected');
            
            if (element.classList.contains('selected')) {
                selectedSlots.add(slotCode);
            } else {
                selectedSlots.delete(slotCode);
            }

            updateSelectedSummary();
        }

        // Update selected slots display
        function updateSelectedSummary() {
            const summary = document.getElementById('selected-summary');
            const list = document.getElementById('selected-slots-list');

            if (selectedSlots.size > 0) {
                summary.style.display = 'flex';
                list.textContent = Array.from(selectedSlots).join(', ');
            } else {
                summary.style.display = 'none';
            }
        }

        // Filter by zone
        function filterZone(zone) {
            // Implementation for zone filtering
            alert('Lọc theo ' + zone);
        }

        // Form submission
        document.getElementById('parking-form').addEventListener('submit', (e) => {
            e.preventDefault();

            // Check if user is logged in
            const userStr = localStorage.getItem('smartpark_user');
            if (!userStr) {
                alert('Bạn cần đăng nhập để thực hiện đặt chỗ!');
                window.location.href = `/login?redirect=${encodeURIComponent(window.location.href)}`;
                return;
            }

            if (selectedSlots.size === 0) {
                alert('Vui lòng chọn ít nhất 1 chỗ đậu');
                return;
            }

            const formData = new FormData(e.target);
            const data = {
                plate: formData.get('plate'),
                vehicleType: formData.get('vehicleType'),
                date: formData.get('date'),
                startTime: formData.get('startTime'),
                endTime: formData.get('endTime'),
                slots: Array.from(selectedSlots),
                totalPrice: document.getElementById('total-price').textContent
            };

            // Redirect to checkout
            window.location.href = `/checkout?${new URLSearchParams(data).toString()}`;
        });

        // Event listeners
        document.getElementById('start-time').addEventListener('change', updateHours);
        document.getElementById('end-time').addEventListener('change', updateHours);

        // Initialize
        updateHours();

        // Update header & autofill plate if user is logged in
        const userStr = localStorage.getItem('smartpark_user');
        if (userStr) {
            try {
                const user = JSON.parse(userStr);
                
                // Header
                const authButtons = document.querySelector('.auth-buttons');
                if (authButtons) {
                    authButtons.innerHTML = `
                        <span style="color: white; margin-right: 15px; font-weight: 500;">👋 Chào, ${user.fullName} (${user.licensePlate})</span>
                        <button onclick="logout()" class="btn-login" style="cursor: pointer; border: none; background: #e11d48; padding: 6px 15px; border-radius: 4px; color: white;">Đăng xuất</button>
                    `;
                }

                // Plate Autofill
                if (user.licensePlate) {
                    document.getElementById('plate').value = user.licensePlate;
                }
            } catch (e) {
                console.error(e);
            }
        }

        function logout() {
            localStorage.removeItem('smartpark_user');
            window.location.reload();
        }
    </script>
</body>
</html>
